# LLM Backend Configuration
# ローカル LLM（大学）の場合:
#   LLM_BASE_URL=http://<GPU-WS-IP>:8080/v1
#   LLM_API_KEY=dummy
#   LLM_MODEL=local
# OpenAI API（自宅）の場合:
#   LLM_BASE_URL=https://api.openai.com/v1
#   LLM_API_KEY=sk-...
#   LLM_MODEL=gpt-4o

LLM_BASE_URL=http://localhost:8080/v1
LLM_API_KEY=dummy
LLM_MODEL=local
